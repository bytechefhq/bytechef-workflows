{
    "label" : "out of working hours",
    "description" : "Out-of-hours Gmail auto-response with AI urgency triage + log to Google Sheets",
    "inputs" : [ ],
    "triggers" : [
        {
            "label" : "New Email",
            "name" : "trigger_1",
            "type" : "googleMail/v1/newEmail",
            "parameters" : {
                "topicName" : "customer-inbox",
                "format" : "FULL"
            }
        }
    ],
    "tasks" : [
        {
            "label" : "Current timestamp",
            "name" : "dateHelper_2",
            "type" : "dateHelper/v1/getCurrentDate",
            "parameters" : {
                "timeZone" : "UTC",
                "dateFormat" : "yyyy-MM-dd'T'HH:mm:ss"
            },
            "metadata" : {
                "ui" : {
                    "dynamicPropertyTypes" : { }
                }
            }
        },
        {
            "label" : "Is business hours?",
            "name" : "dateHelper_1",
            "type" : "dateHelper/v1/isBusinessHours",
            "parameters" : {
                "inputDate" : "${dateHelper_2}",
                "businessWeekStart" : 1,
                "businessWeekEnd" : 5,
                "businessHoursStart" : "09:00:00",
                "businessHoursEnd" : "17:00:00",
                "timeZone" : "UTC",
                "date" : "${dateHelper_2}"
            },
            "metadata" : {
                "ui" : {
                    "dynamicPropertyTypes" : { }
                }
            }
        },
        {
            "clusterElements" : { },
            "description" : "",
            "label" : "Is outside working hours?",
            "maxRetries" : 0,
            "metadata" : {
                "ui" : {
                    "dynamicPropertyTypes" : { }
                }
            },
            "name" : "condition_1",
            "parameters" : {
                "rawExpression" : true,
                "expression" : "${dateHelper_1}",
                "caseTrue" : [ ],
                "caseFalse" : [
                    {
                        "label" : "AI urgency classification",
                        "name" : "openAi_1",
                        "type" : "openAi/v1/ask",
                        "parameters" : {
                            "model" : "gpt-4o-mini",
                            "format" : "SIMPLE",
                            "systemPrompt" : "You classify incoming customer emails received outside working hours. Return ONLY JSON.",
                            "userPrompt" : "Classify urgency for this email.\n\nSubject: ${trigger_1.subject}\nFrom: ${trigger_1.from}\nBody: ${trigger_1.bodyPlain}\n\nReturn JSON with keys: urgent (boolean) and reason (string). ",
                            "response" : {
                                "responseFormat" : "JSON",
                                "responseSchema" : "{\"type\":\"object\",\"properties\":{\"urgent\":{\"type\":\"boolean\"},\"reason\":{\"type\":\"string\"}},\"required\":[\"urgent\",\"reason\"]}"
                            }
                        },
                        "metadata" : {
                            "ui" : {
                                "dynamicPropertyTypes" : {
                                    "userPrompt" : "STRING"
                                }
                            }
                        }
                    },
                    {
                        "label" : "Log to Google Sheets",
                        "name" : "googleSheets_1",
                        "type" : "googleSheets/v1/insertRow",
                        "parameters" : {
                            "spreadsheetId" : "1A_QAWoLPUzCEo1nA5ElwKDCwaNkvfTm-WdSNk8ppztk",
                            "valueInputOption" : "RAW",
                            "isTheFirstRowHeader" : false,
                            "sheetName" : "Sheet1",
                            "row" : {
                                "Timestamp" : "${dateHelper_2}",
                                "From" : "${trigger_1.from}",
                                "Subject" : "${trigger_1.subject}",
                                "Body" : "${trigger_1.bodyPlain}",
                                "Urgent" : "${jsonHelper_1.urgent}",
                                "Reason" : "${jsonHelper_1.reason}",
                                "Suggested Reply" : "${jsonHelper_1.suggested_reply}",
                                "Message Id" : "${trigger_1.id}",
                                "values" : [
                                    "${openAi_1.urgent}",
                                    "${openAi_1.reason}"
                                ]
                            }
                        },
                        "metadata" : {
                            "ui" : {
                                "dynamicPropertyTypes" : {
                                    "row.values[0]" : "BOOLEAN",
                                    "row.values[1]" : "STRING"
                                }
                            }
                        }
                    },
                    {
                        "label" : "Is it urgent?",
                        "name" : "condition_2",
                        "type" : "condition/v1",
                        "parameters" : {
                            "rawExpression" : true,
                            "expression" : "${openAi_1.urgent}",
                            "caseTrue" : [
                                {
                                    "label" : "OpenAI",
                                    "name" : "openAi_2",
                                    "parameters" : {
                                        "format" : "SIMPLE",
                                        "response" : {
                                            "responseFormat" : "TEXT"
                                        },
                                        "n" : 1,
                                        "temperature" : 1,
                                        "topP" : 1,
                                        "frequencyPenalty" : 0,
                                        "presencePenalty" : 0,
                                        "model" : "gpt-4o-mini",
                                        "userPrompt" : "Generate a message for the internal support team.\n\nSubject: ${trigger_1.subject}\nFrom: ${trigger_1.from}\nBody: ${trigger_1.bodyPlain}\n\nReturn only the message text.",
                                        "systemPrompt" : "An incoming email has been classified as URGENT. Summarize the issue clearly and generate a message for the internal team who needs to resolve it."
                                    },
                                    "type" : "openAi/v1/ask",
                                    "metadata" : {
                                        "ui" : {
                                            "dynamicPropertyTypes" : {
                                                "userPrompt" : "STRING",
                                                "systemPrompt" : "STRING"
                                            }
                                        }
                                    }
                                },
                                {
                                    "label" : "Urgent auto-reply",
                                    "name" : "googleMail_2",
                                    "type" : "googleMail/v1/replyToEmail",
                                    "parameters" : {
                                        "id" : "${trigger_1.id}",
                                        "to" : [
                                            "${trigger_1.from}"
                                        ],
                                        "bodyType" : "plain",
                                        "body" : "Thank you for contacting us. This message was received outside of our working hours and has been classified as urgent. It has been forwarded to our team and we will respond as soon as possible once we are available.\n\n— Automated response"
                                    },
                                    "metadata" : {
                                        "ui" : {
                                            "dynamicPropertyTypes" : {
                                                "body" : "STRING"
                                            }
                                        }
                                    }
                                },
                                {
                                    "label" : "Slack",
                                    "name" : "slack_1",
                                    "parameters" : {
                                        "channel" : "C08A5AVRHMZ",
                                        "text" : "${openAi_2}"
                                    },
                                    "type" : "slack/v1/sendChannelMessage",
                                    "metadata" : {
                                        "ui" : {
                                            "dynamicPropertyTypes" : {
                                                "text" : "STRING"
                                            }
                                        }
                                    }
                                }
                            ],
                            "caseFalse" : [
                                {
                                    "label" : "OpenAI",
                                    "name" : "openAi_3",
                                    "parameters" : {
                                        "format" : "SIMPLE",
                                        "response" : {
                                            "responseFormat" : "TEXT"
                                        },
                                        "n" : 1,
                                        "temperature" : 1,
                                        "topP" : 1,
                                        "frequencyPenalty" : 0,
                                        "presencePenalty" : 0,
                                        "model" : "gpt-4o-mini",
                                        "userPrompt" : "Generate a response message for the customer.\n\nSubject: ${trigger_1.subject}\nFrom: ${trigger_1.from}\nBody: ${trigger_1.bodyPlain}\n\nReturn only the message text.",
                                        "systemPrompt" : "An incoming email has been classified as NOT urgent. If the issue can be resolved based on the information provided, generate a helpful and clear response with a solution.If the issue cannot be resolved directly, generate a polite response acknowledging the request and informing the sender that a team member will follow up."
                                    },
                                    "type" : "openAi/v1/ask",
                                    "metadata" : {
                                        "ui" : {
                                            "dynamicPropertyTypes" : {
                                                "userPrompt" : "STRING",
                                                "systemPrompt" : "STRING"
                                            }
                                        }
                                    }
                                },
                                {
                                    "label" : "Not urgent auto-reply",
                                    "name" : "googleMail_3",
                                    "type" : "googleMail/v1/replyToEmail",
                                    "parameters" : {
                                        "id" : "${trigger_1.id}",
                                        "to" : [
                                            "${trigger_1.from}"
                                        ],
                                        "bodyType" : "plain",
                                        "body" : "${openAi_3}"
                                    },
                                    "metadata" : {
                                        "ui" : {
                                            "dynamicPropertyTypes" : {
                                                "body" : "STRING"
                                            }
                                        }
                                    }
                                }
                            ]
                        },
                        "metadata" : {
                            "ui" : {
                                "dynamicPropertyTypes" : {
                                    "expression" : "STRING"
                                }
                            }
                        }
                    }
                ]
            },
            "type" : "condition/v1"
        }
    ]
}